# =============================================================================
# Product Design Partner — gitignore
# Keeps the repo clean for handoff: ship references + agent logic; ignore
# per-designer runtime output and local install artifacts.
# =============================================================================

# --- Runtime design output (your work lives here — never commit) ---
design-data/projects/*
!design-data/projects/.gitkeep
!design-data/projects/README.md

design-data/components/*
!design-data/components/.gitkeep

design-data/tokens/*
!design-data/tokens/.gitkeep

design-data/validation-history/*
!design-data/validation-history/.gitkeep

design-data/variance-history.json

# --- Local install / test artifacts inside the repo ---
.config/
.pdp-test/
test-install/
*.test-install/

# --- Dependencies (only if someone adds npm tooling locally) ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json

# --- OS junk ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Editors & IDEs ---
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Backups & scratch ---
*.backup
*.backup-*
*.bak
*.tmp
*.temp
scratch/
tmp/

# --- Optional local overrides (never commit team-specific tweaks) ---
*.local.md
design-data/references/*.local.*
